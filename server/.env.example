# Copie este arquivo para .env e preencha com seus dados reais.
# NUNCA commite o arquivo .env no git.

# Chave de API da Asaas (produção ou sandbox)
ASAAS_KEY=$aact_SUACHAVEAQUI

# URL base da API Asaas
# Produção: https://api.asaas.com/v3
# Sandbox (testes): https://sandbox.asaas.com/api/v3
ASAAS_URL=https://api.asaas.com/v3

# Porta em que o servidor backend vai rodar
PORT=3001

# Origem permitida para CORS (domínio onde o index.html está hospedado)
ALLOWED_ORIGIN=https://seu-dominio.com

# URL do Web App do Google Apps Script (doPost) que recebe os webhooks do Asaas
GAS_WEBHOOK_URL=https://script.google.com/macros/s/SEU_SCRIPT_ID/exec

# Token enviado pelo Asaas no header "asaas-access-token" para validar o webhook
# (configure o mesmo valor em Asaas > Integrações > Webhooks)
ASAAS_WEBHOOK_TOKEN=defina_um_token_secreto_aqui
